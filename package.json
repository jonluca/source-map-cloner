{
  "name": "source-map-cloner",
  "version": "0.0.0-development",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonluca/source-map-cloner"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": "dist/src/cli/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./cli": {
      "import": "./dist/src/cli/index.js",
      "types": "./dist/src/cli/index.d.ts"
    },
    "./fetchers": {
      "import": "./dist/src/fetchers/index.js",
      "types": "./dist/src/fetchers/index.d.ts"
    },
    "./src/*": {
      "import": "./src/*",
      "types": "./src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "format:check": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "tsx --test tests/*.test.ts",
    "test:live": "tsx scripts/test-live-source-maps.ts",
    "typecheck": "tsc --noEmit && pnpm --filter webapp typecheck",
    "fetch-source": "tsx src/cli/index.ts",
    "dev-webapp": "pnpm --filter webapp dev"
  },
  "files": [
    "tsconfig.json",
    "src",
    "dist/src",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "dependencies": {
    "crawler": "^2.0.2",
    "got": "^15.0.5",
    "iconv-lite": "^0.7.2",
    "jsdom": "^29.1.1",
    "mkdirp": "^3.0.1",
    "p-map": "^7.0.4",
    "source-map": "^0.7.6",
    "top-user-agents": "^2.1.111",
    "tough-cookie": "^6.0.1",
    "vm2": "^3.11.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/crawler": "^1.2.7",
    "@types/jsdom": "^28.0.1",
    "@types/node": "25.6.2",
    "@types/yargs": "^17.0.35",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.0.9",
  "workspaces": [
    "webapp"
  ]
}
